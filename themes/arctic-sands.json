  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#3d4f6b", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#a8ff78" }
    },
    {
      "name": "String escape",
      "scope": "constant.character.escape",
      "settings": { "foreground": "#00c8ff" }
    },
    {
      "name": "Number / Boolean / Null",
      "scope": ["constant.numeric", "constant.language"],
      "settings": { "foreground": "#f78166" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#ff79c6", "fontStyle": "italic" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "punctuation.separator"],
      "settings": { "foreground": "#89ddff" }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": { "foreground": "#82aaff" }
    },
    {
      "name": "Class / Type",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#00c8ff" }
    },
    {
      "name": "Interface / Type alias",
      "scope": ["entity.name.type.interface", "entity.name.type.alias"],
      "settings": { "foreground": "#00c8ff", "fontStyle": "italic" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other.readwrite"],
      "settings": { "foreground": "#c9d1d9" }
    },
    {
      "name": "Variable — property",
      "scope": ["variable.other.property", "support.variable.property"],
      "settings": { "foreground": "#e2a84b" }
    },
    {
      "name": "Parameter",
      "scope": "variable.parameter",
      "settings": { "foreground": "#d2a8ff", "fontStyle": "italic" }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag", "meta.tag"],
      "settings": { "foreground": "#ff79c6" }
    },
    {
      "name": "Tag attribute",
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#82aaff" }
    },
    {
      "name": "CSS property",
      "scope": "support.type.property-name",
      "settings": { "foreground": "#00c8ff" }
    },
    {
      "name": "CSS value",
      "scope": "support.constant.property-value",
      "settings": { "foreground": "#a8ff78" }
    },
    {
      "name": "CSS selector",
      "scope": "entity.name.tag.css",
      "settings": { "foreground": "#ff79c6" }
    },
    {
      "name": "CSS class/id selector",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": { "foreground": "#e2a84b" }
    },
    {
      "name": "Import / Module",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": { "foreground": "#ff79c6", "fontStyle": "italic" }
    },
    {
      "name": "Constant",
      "scope": ["constant", "variable.other.constant"],
      "settings": { "foreground": "#f78166" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation.definition", "punctuation.terminator"],
      "settings": { "foreground": "#8b949e" }
    },
    {
      "name": "Decorator / Annotation",
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#e2a84b", "fontStyle": "italic" }
    },
    {
      "name": "Markdown heading",
      "scope": "markup.heading",
      "settings": { "foreground": "#00c8ff", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": "markup.bold",
      "settings": { "foreground": "#e6edf3", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": "markup.italic",
      "settings": { "foreground": "#c9d1d9", "fontStyle": "italic" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#a8ff78" }
    },
    {
      "name": "Markdown link",
      "scope": "markup.underline.link",
      "settings": { "foreground": "#00c8ff" }
    },
    {
      "name": "Invalid",
      "scope": "invalid",
      "settings": { "foreground": "#ff4757", "fontStyle": "underline" }
    }
  ]
}
